# ─────────────────────────────────────────────────────────────
#  .env.test — окружение ТЕСТОВОГО двойника Сони (сервис bot-test)
#  Режим web-only: тестируем через веб-виджет, Telegram-бот НЕ нужен.
#  Демо-страница после запуска: http://<сервер>:8081/web/demo
#  amoCRM/amoJo/алерты выключены → полная изоляция от прода.
#  БД отдельная (том ./data-test), в /admin и /owner прода не видна.
# ─────────────────────────────────────────────────────────────
# ===== Telegram =====
# web-only режим: бота не поднимаем, токен можно не указывать
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=

# ===== OpenRouter (LLM) =====
OPENROUTER_API_KEY=sk-or-...      # можно тот же ключ, что у прода
# Любая модель из OpenRouter, например anthropic/claude-sonnet-4.5 или openai/gpt-4o-mini
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
# Необязательные заголовки атрибуции OpenRouter
OPENROUTER_APP_URL=https://cvety-naberezhnye.ru
OPENROUTER_APP_NAME=Sonya Flower Bot

# ===== Каталог WooCommerce =====
WOO_BASE_URL=https://cvety-naberezhnye.ru
WOO_CACHE_TTL=1800           # сек, как часто обновлять кэш каталога
WOO_MAX_PRODUCTS=400         # сколько товаров подтягивать максимум

# ===== amoCRM (REST, сделки) =====
# Домен вашего аккаунта, напр. myshop.amocrm.ru
AMO_BASE_URL=
AMO_CLIENT_ID=
AMO_CLIENT_SECRET=
AMO_REDIRECT_URI=
# Первичный код авторизации (одноразовый) ИЛИ уже готовые токены:
AMO_AUTH_CODE=
AMO_ACCESS_TOKEN=
AMO_REFRESH_TOKEN=
# Куда класть сделку (заполнить через scripts/amo_bootstrap.py)
AMO_PIPELINE_ID=
AMO_STATUS_ID=
# ID кастомных полей СДЕЛКИ (из amo_bootstrap.py)
AMO_CF_PRODUCT=
AMO_CF_PRODUCT_URL=
AMO_CF_PRICE=
AMO_CF_BUDGET=
AMO_CF_DELIVERY=
AMO_CF_SOURCE=
# ID кастомных полей КОНТАКТА (телефон обычно уже есть в системном поле)
AMO_CF_CONTACT_PHONE=

# ===== amoCRM Chat API (amoJo, двусторонний чат) =====
# Получить через регистрацию канала чата (scripts/amo_bootstrap.py)
AMOJO_BASE_URL=https://amojo.amocrm.ru
AMOJO_CHANNEL_ID=
AMOJO_CHANNEL_SECRET=
AMOJO_SCOPE_ID=
# amoCRM account uuid (account_id в amoJo), берётся при connect
AMOJO_ACCOUNT_ID=

# ===== Webhook сервер (приём ответов менеджера из amoJo) =====
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
# Публичный путь, который укажете при регистрации канала
WEBHOOK_PATH=/amojo/webhook

# ===== Виджет amoCRM (чат-панель в карточке) =====
WIDGET_PUBLIC_URL=https://144-31-108-55.sslip.io
WIDGET_TOKEN=   # общий секрет; тот же впишется в виджет

# ===== Админка (/admin — список диалогов, пользователей и стоимости) =====
ADMIN_TOKEN=test
USD_RUB_RATE=0                # курс USD→RUB для показа стоимости в рублях (0 — только $)

# ===== Кабинет владельца (/owner — то же, но расходы с наценкой) =====
OWNER_TOKEN=test
OWNER_COST_MARKUP=12          # множитель стоимости (наценка); в интерфейсе не виден

# ===== Уведомления о низком балансе кошелька владельца (отдельный бот) =====
NOTIFY_BOT_TOKEN=   # токен бота-уведомлятора (@BotFather); пусто — сторож выключен
NOTIFY_CHAT_ID=   # Telegram chat_id получателя (нажать Start у бота-уведомлятора)
WALLET_ALERT_ENABLED=false
WALLET_ALERT_THRESHOLD_RUB=500  # слать алерт, когда остаток кошелька падает ниже, ₽

# ===== Веб-виджет (канал тестирования) =====
WEB_ENABLED=true
WEB_ALLOWED_ORIGINS=*          # тестовый стенд — принимаем любой origin

# ===== Прочее =====
DB_PATH=data/bot.db
LOG_LEVEL=INFO
